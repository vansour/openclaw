{
  channels: {
    telegram: {
      enabled: true,
      botToken: "${TELEGRAM_BOT_TOKEN}",
      dmPolicy: "pairing",
      groups: {
        "*": {
          requireMention: true,
        },
      },
    },
  },

  models: {
    mode: "merge",
    providers: {
      "vansour-openai": {
        baseUrl: "https://newapi.vansour.net/v1",
        apiKey: "${VANSOUR_OPENAI_API_KEY}",
        api: "openai-responses",
        authHeader: true,
        models: [
          {
            id: "gpt-5.4",
            name: "GPT-5.4",
            api: "openai-responses",
            reasoning: true,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 128000,
            maxTokens: 32000,
          },
        ],
      },
    },
  },

  agents: {
    defaults: {
      model: { primary: "vansour-openai/gpt-5.4" },
      models: {
        "vansour-openai/gpt-5.4": {
          alias: "gpt",
        },
      },
    },
  },
}
